{
  "name": "harness-chat-desktop",
  "version": "1.0.0",
  "description": "Harness Chat as a native desktop app — a thin shell over harness-chat-web.",
  "main": "main.js",
  "author": "Jaden Kwek",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.jadenkwek.harnesschat.desktop",
    "productName": "Harness Chat",
    "directories": { "output": "dist" },
    "files": ["main.js", "package.json", "assets/**/*"],
    "mac": { "category": "public.app-category.productivity", "target": "dir", "icon": "assets/icon.icns" }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
